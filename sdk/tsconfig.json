{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "lib": ["ES2022"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "bin/**/*.ts", "../config/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
