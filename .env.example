# ============================================================================
# Sigil Protocol — Environment Variables
# ============================================================================
# Copy to .env and fill in values. NEVER commit .env (only .env.example).
# Anti-Hallucination Rule 4: only use vars declared here. If a new one is
# needed, add it to this file FIRST.
# ============================================================================

# ----------------------------------------------------------------------------
# 0G Network — Galileo Testnet
# ----------------------------------------------------------------------------
# Chain ID is 16602 (NOT 16600 as some older docs may say).
ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_CHAIN_ID=16602
ZERO_G_EXPLORER_URL=https://chainscan-galileo.0g.ai

# Deployer wallet — pays gas for SigilRegistry + ProvenanceNotary deployment.
# Generate fresh; do NOT reuse a personal wallet. Fund via https://faucet.0g.ai
ZERO_G_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# 0G Storage (KV + Log)
# ----------------------------------------------------------------------------
# Storage node RPC + stream IDs for the protocol's KV (encrypted manifests +
# input contexts) and Log (append-only fingerprints, attestations, provenance
# refs).
ZERO_G_STORAGE_RPC=
ZERO_G_STORAGE_KV_STREAM=
ZERO_G_STORAGE_LOG_STREAM=

# ----------------------------------------------------------------------------
# 0G Compute (sealed inference)
# ----------------------------------------------------------------------------
# Default model — use `qwen/qwen-2.5-7b-instruct` (verified available on
# testnet 2026-04-29 via readonly broker listService). The `qwen/` prefix is
# REQUIRED — passing it without the vendor prefix will not match.
# Mainnet has additional models; if running against mainnet, override here.
ZERO_G_COMPUTE_RPC=
ZERO_G_COMPUTE_DEFAULT_MODEL=qwen/qwen-2.5-7b-instruct

# ----------------------------------------------------------------------------
# Deployed Sigil Contracts (fill after Phase 1 deployment)
# ----------------------------------------------------------------------------
# These get auto-written to deployments/testnet.json by scripts/deploy.ts and
# can be sourced from there. Duplicating here for SDK convenience.
SIGIL_REGISTRY_ADDRESS=
PROVENANCE_NOTARY_ADDRESS=

# ----------------------------------------------------------------------------
# KeeperHub (execution + audit trail)
# ----------------------------------------------------------------------------
# Sign up at https://app.keeperhub.com, get key from dashboard.
KEEPERHUB_API_KEY=

# Workflow ID for the "Sigil Attest" KeeperHub workflow that calls
# appendFingerprint + appendAttestation on SigilRegistry via the Para MPC
# wallet. Created via KeeperHub dashboard or MCP.
KEEPERHUB_WORKFLOW_ID=

# Comma-separated list of KeeperHub relay addresses authorized to call
# `appendFingerprint` and `appendAttestation`. Stored on-chain in a
# `mapping(address => bool) keeperRelays` set, NOT a single address (relay
# keys rotate). Owner can add/remove via `addRelay`/`removeRelay`.
KEEPERHUB_RELAY_ADDRESSES=

# ----------------------------------------------------------------------------
# Auto-attest sidecar (DEMO SIMULATOR)
# ----------------------------------------------------------------------------
# Optional. When set, every successful provenance.notarize() in the demo also
# fires SigilRegistry.appendAttestation() so the agent's reputation/taskCount
# move in real time. Two modes:
#
# Mode 1 — KeeperHub Para MPC wallet (preferred for demo):
#   Set KEEPERHUB_API_KEY + KEEPERHUB_WORKFLOW_ID above. The KeeperHub Para
#   MPC wallet signs on-chain — no private key needed here. Register the
#   KeeperHub Para MPC wallet address as a relay first:
#     SIGIL_KEEPER_RELAY_ADDRESS=<keeperhub-para-mpc-wallet>
#     pnpm --filter sigil-demo run add-relay
#
# Mode 2 — Local relay wallet (legacy):
#   Set SIGIL_KEEPER_RELAY_PRIVATE_KEY to a wallet private key. Register its
#   address as a relay:
#     pnpm --filter sigil-demo run add-relay

# Direct address of a KeeperHub Para MPC wallet (or any relay address where
# you don't have the private key). Used by add-relay to register it on-chain.
SIGIL_KEEPER_RELAY_ADDRESS=

# Private key of a local relay wallet. Used by add-relay (if
# SIGIL_KEEPER_RELAY_ADDRESS is not set) and by the direct-mode sidecar.
SIGIL_KEEPER_RELAY_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# Demo wallets
# ----------------------------------------------------------------------------
# DEMO_PRINCIPAL_PRIVATE_KEY: human wallet that calls register() and
# authorizes the agent at registration time.
# DEMO_AGENT_PRIVATE_KEY: agent wallet that signs notarizations autonomously
# after the principal has authorized it.
DEMO_PRINCIPAL_PRIVATE_KEY=
DEMO_AGENT_PRIVATE_KEY=

# ----------------------------------------------------------------------------
# Sigil API server (Phase 5b — onboarding surface for SKILL.md flow)
# ----------------------------------------------------------------------------
API_SERVER_PORT=3001
API_SERVER_BASE_URL=https://sigil-demo.trycloudflare.com
# In-memory pending-registration TTL in ms. 24h = 86400000.
API_PENDING_TTL_MS=86400000
# Rate limits.
API_RATE_LIMIT_PER_IP_PER_HOUR=5
API_MAX_PENDING_PER_PRINCIPAL=10

# Sigil relayer wallet — pays gas for SKILL.md sponsored registrations so new
# agents don't need to fund a wallet before onboarding. Fund via faucet.
SIGIL_RELAYER_PRIVATE_KEY=
SIGIL_RELAYER_ADDRESS=

# ----------------------------------------------------------------------------
# Sigil MCP server (Phase 5b — onboarding surface for MCP-based agents)
# ----------------------------------------------------------------------------
# Local stdio transport: agent reads its own private key from this env var.
# Never sent over the wire; never logged (redactSensitiveFields middleware).
SIGIL_AGENT_PRIVATE_KEY=

# Remote SSE transport: bind address + port. Remote MCP exposes only
# register/resolve/verify; notarize_output is rejected because it would
# require the private key in the request payload.
MCP_SERVER_PORT=3002
MCP_SERVER_HOST=0.0.0.0

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# pino log level: debug | info | warn | error. Default info in production,
# debug in development.
LOG_LEVEL=info
NODE_ENV=development
